# .env.example
# ------------
# Copy this file to .env and fill in the values for your environment.
# .env is listed in .gitignore and must NEVER be committed to source control.
#
# Load at runtime with:
#   export $(grep -v '^#' .env | xargs)      # bash
#   python-dotenv (if added to requirements)
#
# ─────────────────────────────────────────────────────────────────────────────
# FLASK / APPLICATION
# ─────────────────────────────────────────────────────────────────────────────

# Runtime environment: development | testing | production
FLASK_ENV=development

# Secret key used by Flask for session signing and CSRF protection.
# REQUIRED in production – must be a long, random, unique string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# SQLAlchemy database URL.
# REQUIRED in production.  Leave unset in development to use the default
# SQLite file (instance/customers_dev.db).
#
# Examples:
#   sqlite:///customers.db
#   postgresql://user:password@localhost:5432/customers_db
#   mysql+pymysql://user:password@localhost/customers_db
DATABASE_URL=sqlite:///customers_dev.db

# ─────────────────────────────────────────────────────────────────────────────
# THIRD-PARTY ENRICHMENT API
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the enrichment API provider.
# Default: https://jsonplaceholder.typicode.com (free public sandbox, no key).
# Set this to a real provider (e.g. Clearbit, FullContact) in production.
ENRICHMENT_API_BASE_URL=https://jsonplaceholder.typicode.com

# Bearer token / API key for the enrichment provider.
# Leave blank or unset when using the public JSONPlaceholder sandbox.
# In production, obtain this from your provider's dashboard and store it
# in your secrets manager (see SECRETS_BACKEND below).
ENRICHMENT_API_KEY=

# Per-request timeout in seconds.  Requests that exceed this are aborted
# and raise ExternalAPITimeoutError.
ENRICHMENT_API_TIMEOUT=10

# Maximum retry attempts on transient failures (5xx / network errors).
# Each retry waits ENRICHMENT_API_BACKOFF × 2^(attempt-1) seconds.
ENRICHMENT_API_MAX_RETRIES=3

# Exponential back-off multiplier in seconds.
ENRICHMENT_API_BACKOFF=0.5

# ─────────────────────────────────────────────────────────────────────────────
# SECRETS BACKEND (vault integration)
# ─────────────────────────────────────────────────────────────────────────────
# Controls where app/secrets.py fetches secret values.
#
#   env (default)            – read from environment variables only
#   aws_secrets_manager      – read from AWS Secrets Manager
#                              (requires boto3; see app/secrets.py)
#
SECRETS_BACKEND=env

# ── AWS Secrets Manager settings (only used when SECRETS_BACKEND=aws_secrets_manager) ──

# AWS region where your secrets are stored.
AWS_REGION=us-east-1

# Prefix prepended to every secret name: <SECRETS_NAME_PREFIX>/<KEY>
# Example: app/ENRICHMENT_API_KEY
SECRETS_NAME_PREFIX=app

# AWS credentials.  Prefer IAM roles (EC2/ECS/Lambda) over static keys.
# Leave blank when using an IAM role – boto3 resolves them automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
